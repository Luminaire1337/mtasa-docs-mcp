{
  "name": "mtasa-docs-mcp",
  "version": "1.0.2",
  "description": "MCP server for MTA:SA documentation with intelligent search and caching",
  "type": "module",
  "license": "GPL-3.0",
  "author": "Luminaire1337",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luminaire1337/mtasa-docs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Luminaire1337/mtasa-docs-mcp/issues"
  },
  "homepage": "https://github.com/Luminaire1337/mtasa-docs-mcp#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "mtasa",
    "multi-theft-auto",
    "documentation",
    "ai",
    "vector-search",
    "sqlite"
  ],
  "bin": {
    "mtasa-docs-mcp": "./build/index.js"
  },
  "scripts": {
    "prepack": "node scripts/build.mjs",
    "build": "node scripts/build.mjs",
    "inspector": "pnpx @modelcontextprotocol/inspector node ./build/index.js",
    "check:versions": "node scripts/check-version-consistency.mjs",
    "check:changelog": "node scripts/check-changelog-consistency.mjs",
    "release:check-tag": "node scripts/check-release-tag.mjs",
    "release:notes": "node scripts/extract-changelog-entry.mjs",
    "check:tool-names": "node scripts/check-tool-name-drift.mjs",
    "test": "vitest run",
    "test:runtime": "vitest run --config vitest.runtime.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "vitest run --config vitest.live.config.ts",
    "smoke": "pnpm smoke:node",
    "smoke:node": "node scripts/build.mjs && node scripts/smoke.mjs --runtime=node",
    "smoke:bun": "node scripts/build.mjs && node scripts/smoke.mjs --runtime=bun",
    "smoke:cross-runtime": "pnpm smoke:node && pnpm smoke:bun",
    "verify": "pnpm check:versions && pnpm check:changelog && pnpm check:tool-names && tsc --noEmit && vitest run && pnpm smoke",
    "verify:full": "pnpm verify && pnpm test:live"
  },
  "files": [
    "build/index.js"
  ],
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sqliteai/sqlite-vector": "^0.9.94",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
